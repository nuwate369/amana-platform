{
  "expo": {
    "name": "أمانة سائقة",
    "slug": "amana-driver",
    "scheme": "amana-driver",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/images/logo.png",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1e3d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "sa.amana.driver"
    },
    "android": {
      "package": "sa.amana.driver",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#0f1e3d"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "يستخدم تطبيق أمانة صورك لرفع مستندات التحقّق (الهوية، الرخصة، الاستمارة، صورة السيارة).",
          "cameraPermission": "يستخدم تطبيق أمانة الكاميرا لالتقاط صور مستندات التحقّق مباشرةً."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "appName": "driver"
    }
  }
}
