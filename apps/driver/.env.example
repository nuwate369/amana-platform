# تطبيق السائقة — متغيرات البيئة (انسخ الملف إلى .env واملأ القيم الحقيقية)
# تُقرأ المتغيرات ذات البادئة EXPO_PUBLIC_ على العميل، لذا لا تضع هنا أي مفتاح سري.

# رابط مشروع Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# المفتاح العام anon (آمن على العميل)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# مفتاح Mapbox العام (pk.) لعرض الخرائط — من account.mapbox.com → Access tokens
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# ملاحظة: مفتاح service role لا يوضع هنا إطلاقًا — مكانه فقط في مشروع admin على الخادم.
# ملاحظة build: مفتاح تنزيل Mapbox السرّي (sk. بنطاق DOWNLOADS:READ) يُضبط كـ eas secret
# باسم MAPBOX_DOWNLOADS_TOKEN وقت eas build (لا يوضع في الكود أو Git).
