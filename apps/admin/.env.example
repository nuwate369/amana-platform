# لوحة الإدارة — متغيرات البيئة (انسخ الملف إلى .env.local واملأ القيم الحقيقية)

# ---- عامة (تُقرأ على العميل) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- سرّية (الخادم فقط — لا تبدأ بـ NEXT_PUBLIC ولا تُسرّب للعميل) ----
# مفتاح service role: يُستخدم حصريًا داخل Server Actions لعمليات الإدارة.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
