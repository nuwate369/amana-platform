{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@amana/shared-types": ["../../packages/shared-types/src"],
      "@amana/shared-ui": ["../../packages/shared-ui/src"],
      "@amana/shared-ui/tokens": ["../../packages/shared-ui/src/tokens"],
      "@amana/supabase-client": ["../../packages/supabase-client/src"],
      "@amana/i18n": ["../../packages/i18n/src"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "nativewind-env.d.ts"]
}
