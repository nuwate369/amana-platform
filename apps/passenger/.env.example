# تطبيق الراكبة — متغيرات البيئة (انسخ الملف إلى .env واملأ القيم الحقيقية)
# تُقرأ المتغيرات ذات البادئة EXPO_PUBLIC_ على العميل، لذا لا تضع هنا أي مفتاح سري.

# رابط مشروع Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# المفتاح العام anon (آمن على العميل)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# رابط لوحة الإدارة (لمسارات الذكاء الاصطناعي مثل الدعم الفني الذكيّ عبر Groq)
# الإنتاج: https://amana.nuwate.com — للتجربة محليًّا على الهاتف: http://<IP-الحاسوب>:3002
EXPO_PUBLIC_ADMIN_API_URL=https://your-admin-host

# ملاحظة: مفتاح service role لا يوضع هنا إطلاقًا — مكانه فقط في مشروع admin على الخادم.

# جذر خادم Metro = مجلّد التطبيق لا جذر الـ Monorepo.
# بدونه يُولَّد مسار نقطة دخول خاطئ فينكسر تجميع نسخة الإصدار (assembleRelease).
EXPO_NO_METRO_WORKSPACE_ROOT=1
